# Скопируй в .env и заполни. Файл .env закоммичен в .gitignore.

# --- API ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
POSTGRES_USER=embeding
POSTGRES_PASSWORD=change-me
POSTGRES_DB=embeding

# --- Хост-порты (опционально; дефолты стандартные) ---
# Раскомментируй/смени, если порты заняты другими сервисами.
# POSTGRES_PORT=5432
# OLLAMA_PORT=11434
# API_PORT=3000
# WEB_PORT=8080
# Вне docker: host=localhost. Внутри сети docker-compose: host=postgres.
DATABASE_URL=postgresql://embeding:change-me@localhost:5432/embeding?schema=public

# --- Ollama ---
# Вне docker: http://localhost:11434. Внутри compose: http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=120000
OLLAMA_KEEP_ALIVE=5m

# --- Redis (очередь BullMQ). Внутри compose host=redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Конкуренция инференса (CPU-only) ---
CHAT_CONCURRENCY=1
EMBED_CONCURRENCY=3

# Bun + BullMQ: нативный msgpackr-extract крашит Bun — отключаем (есть и preload-страховка)
MSGPACKR_NATIVE_ACCELERATION_DISABLED=true

# --- JWT (минимум 16 символов на секрет) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-16
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- API-ключи: pepper для HMAC-хэша (минимум 32 символа) ---
APIKEY_HMAC_SECRET=change-me-apikey-hmac-secret-min-32-chars

# --- Веб / CORS / cookie ---
# WEB_ORIGIN — список origin'ов фронтенда через запятую (для CORS с credentials)
WEB_ORIGIN=http://localhost:8080
# COOKIE_DOMAIN=.example.com   # задать в проде при необходимости
# URL API, как его видит браузер (запекается в фронт на сборке). Пусто = same-origin
# (хостовый nginx роутит / → web и /v1,/auth,/admin,/keys → api). Для прямого доступа:
# WAKU_PUBLIC_API_URL=http://localhost:3000
WAKU_PUBLIC_API_URL=

# --- Лимиты ---
HTTP_BODY_LIMIT=25mb
MAX_EMBED_INPUT_ITEMS=2048
MAX_EMBED_INPUT_CHARS=1000000

# --- Супер-админ (сидится при первом старте через `bun run db:seed`) ---
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password
